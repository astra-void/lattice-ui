{
  "internalScope": "@lattice-ui",
  "internalDependencyVersion": "workspace:*",
  "lockedVersion": "0.4.4",
  "lockedstep": {
    "enforced": true,
    "major": 0
  },
  "packageDefaults": {
    "private": false,
    "main": "out/init.luau",
    "types": "out/index.d.ts",
    "source": "src/index.ts",
    "files": ["out", "src", "README.md"],
    "scripts": {
      "build": "rbxtsc -p tsconfig.json",
      "watch": "rbxtsc -p tsconfig.json -w",
      "typecheck": "tsc -p tsconfig.typecheck.json"
    }
  },
  "defaultPeerDependencies": {
    "@rbxts/react": "^17",
    "@rbxts/react-roblox": "^17"
  },
  "defaultDevDependencies": {
    "@rbxts/react": "17.3.7-ts.1",
    "@rbxts/react-roblox": "17.3.7-ts.1"
  },
  "toolingPackages": ["lattice-ui"],
  "requiredFiles": ["src/index.ts", "tsconfig.json", "tsconfig.typecheck.json"],
  "changesets": {
    "baseBranch": "main",
    "access": "public"
  }
}
