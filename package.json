{
  "name": "lattice-ui-monorepo",
  "version": "0.3.2",
  "private": true,
  "description": "",
  "scripts": {
    "dev": "pnpm run docs:dev",
    "lattice": "node --import tsx ./packages/cli/src/index.ts",
    "package:new": "node --import tsx ./scripts/create-package.ts",
    "workspace:sync": "node --import tsx ./scripts/workspace-sync.ts",
    "workspace:check": "node --import tsx ./scripts/workspace-check.ts",
    "build": "pnpm -r build",
    "build:single": "pnpm -r --workspace-concurrency=1 build",
    "watch": "pnpm -r watch",
    "typecheck": "pnpm -r typecheck",
    "docs:dev": "pnpm --filter @lattice-ui/docs dev",
    "docs:build": "pnpm --filter @lattice-ui/docs build",
    "docs:preview": "pnpm --filter @lattice-ui/docs preview",
    "docs:typecheck": "pnpm --filter @lattice-ui/docs typecheck",
    "preview:harness:dev": "pnpm --dir apps/preview-harness exec vite",
    "preview:harness:build": "pnpm --dir apps/preview-harness exec vite build",
    "preview:harness:typecheck": "pnpm --filter @lattice-ui/preview typecheck && pnpm --filter @lattice-ui/cli typecheck && pnpm --dir apps/preview-harness exec tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest --watch",
    "test:rbx:build": "pnpm --filter @lattice-ui/test-harness build",
    "test:rbx:typecheck": "pnpm --filter @lattice-ui/test-harness typecheck",
    "test:rbx:prepare": "pnpm run test:rbx:typecheck && pnpm run test:rbx:build",
    "test:rbx:place": "rojo build apps/test-harness/default.project.json -o apps/test-harness/test-harness.rbxlx",
    "test:rbx": "pnpm run test:rbx:prepare",
    "test:rbx:headless": "pnpm run test:rbx:prepare && pnpm run test:rbx:place && run-in-roblox --place apps/test-harness/test-harness.rbxlx --script apps/test-harness/scripts/headless.lua",
    "test:rbx:run": "pnpm run test:rbx:prepare && pnpm run test:rbx:place && echo \"Open apps/test-harness/test-harness.rbxlx in Roblox Studio and press Play to run TestEZ suites.\"",
    "lint": "pnpm -w eslint .",
    "lint:fix": "pnpm -w eslint . --fix",
    "format": "pnpm -w prettier . --write",
    "format:check": "pnpm -w prettier . --check",
    "biome:fix": "pnpm -w biome check --fix --unsafe",
    "check:fast": "pnpm run workspace:check && pnpm run lint && pnpm run typecheck",
    "check": "pnpm run check:fast && pnpm run test:unit",
    "verify:types": "pnpm run lint && pnpm run typecheck",
    "verify:workspace": "pnpm run workspace:check && pnpm run verify:types",
    "changeset:add": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status --verbose",
    "changeset:require": "node --import tsx ./scripts/changeset-require.ts",
    "release:prepare": "pnpm run verify:workspace && pnpm run changeset:require && pnpm run changeset:version && pnpm install --lockfile-only",
    "release:publish": "pnpm -r --filter \"./packages/*\" publish --access public --tag latest --report-summary",
    "release:publish:dry-run": "pnpm -r --filter \"./packages/*\" publish --dry-run --access public --tag latest --report-summary",
    "release": "pnpm run release:prepare && pnpm run release:publish",
    "publish:summary": "cat pnpm-publish-summary.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "^2.30.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@lattice-ui/checkbox": "workspace:*",
    "@lattice-ui/core": "workspace:*",
    "@lattice-ui/dialog": "workspace:*",
    "@lattice-ui/focus": "workspace:*",
    "@lattice-ui/layer": "workspace:*",
    "@lattice-ui/menu": "workspace:*",
    "@lattice-ui/popover": "workspace:*",
    "@lattice-ui/popper": "workspace:*",
    "@lattice-ui/radio-group": "workspace:*",
    "@lattice-ui/style": "workspace:*",
    "@lattice-ui/switch": "workspace:*",
    "@lattice-ui/system": "workspace:*",
    "@lattice-ui/tabs": "workspace:*",
    "@lattice-ui/toggle-group": "workspace:*",
    "@lattice-ui/tooltip": "workspace:*",
    "@rbxts/compiler-types": "3.0.0-types.0",
    "@rbxts/react": "17.3.7-ts.1",
    "@rbxts/react-roblox": "17.3.7-ts.1",
    "@rbxts/types": "^1.0.910",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-roblox-ts": "^1.4.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "roblox-ts": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.17.23"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.30.3"
}
