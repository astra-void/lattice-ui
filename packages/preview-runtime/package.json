{
  "name": "@lattice-ui/preview-runtime",
  "version": "0.3.2",
  "private": false,
  "description": "Browser polyfills for Roblox runtime APIs used by Lattice UI previews.",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json -w"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Enum": {
      "types": "./src/Enum.ts",
      "import": "./src/Enum.ts",
      "default": "./src/Enum.ts"
    },
    "./RunService": {
      "types": "./src/RunService.ts",
      "import": "./src/RunService.ts",
      "default": "./src/RunService.ts"
    },
    "./task": {
      "types": "./src/task.ts",
      "import": "./src/task.ts",
      "default": "./src/task.ts"
    }
  }
}
