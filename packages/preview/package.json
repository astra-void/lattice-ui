{
  "name": "@lattice-ui/preview",
  "version": "0.3.2",
  "private": false,
  "description": "Lattice UI source-first preview server and runtime.",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "node ./scripts/clean-dist.mjs",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node ./scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json -w"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "dependencies": {
    "@lattice-ui/compiler": "workspace:*",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4"
  }
}