{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lattice-ui/react-accordion": ["packages/react/accordion/src/index.ts"],
      "@lattice-ui/react-avatar": ["packages/react/avatar/src/index.ts"],
      "@lattice-ui/react-checkbox": ["packages/react/checkbox/src/index.ts"],
      "@lattice-ui/react-combobox": ["packages/react/combobox/src/index.ts"],
      "@lattice-ui/react-runtime": ["packages/react/runtime/src/index.ts"],
      "@lattice-ui/react-dialog": ["packages/react/dialog/src/index.ts"],
      "@lattice-ui/react-layer": ["packages/react/layer/src/index.ts"],
      "@lattice-ui/react-focus": ["packages/react/focus/src/index.ts"],
      "@lattice-ui/react-motion": ["packages/react/motion/src/index.ts"],
      "@lattice-ui/react-menu": ["packages/react/menu/src/index.ts"],
      "@lattice-ui/react-popover": ["packages/react/popover/src/index.ts"],
      "@lattice-ui/react-popper": ["packages/react/popper/src/index.ts"],
      "@lattice-ui/react-progress": ["packages/react/progress/src/index.ts"],
      "@lattice-ui/react-radio-group": ["packages/react/radio-group/src/index.ts"],
      "@lattice-ui/react-scroll-area": ["packages/react/scroll-area/src/index.ts"],
