{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@lattice-ui/accordion": ["packages/accordion/src/index.ts"],
      "@lattice-ui/avatar": ["packages/avatar/src/index.ts"],
      "@lattice-ui/checkbox": ["packages/checkbox/src/index.ts"],
      "@lattice-ui/combobox": ["packages/combobox/src/index.ts"],
      "@lattice-ui/core": ["packages/core/src/index.ts"],
      "@lattice-ui/dialog": ["packages/dialog/src/index.ts"],
      "@lattice-ui/layer": ["packages/layer/src/index.ts"],
      "@lattice-ui/focus": ["packages/focus/src/index.ts"],
      "@lattice-ui/menu": ["packages/menu/src/index.ts"],
      "@lattice-ui/popover": ["packages/popover/src/index.ts"],
      "@lattice-ui/popper": ["packages/popper/src/index.ts"],
      "@lattice-ui/preview": ["packages/preview/src/index.ts"],
      "@lattice-ui/preview/runtime": ["packages/preview/src/runtime/index.ts"],
      "@lattice-ui/progress": ["packages/progress/src/index.ts"],
      "@lattice-ui/radio-group": ["packages/radio-group/src/index.ts"],
      "@lattice-ui/scroll-area": ["packages/scroll-area/src/index.ts"],
      "@lattice-ui/select": ["packages/select/src/index.ts"],
      "@lattice-ui/slider": ["packages/slider/src/index.ts"],
      "@lattice-ui/style": ["packages/style/src/index.ts"],
      "@lattice-ui/system": ["packages/system/src/index.ts"],
      "@lattice-ui/switch": ["packages/switch/src/index.ts"],
      "@lattice-ui/tabs": ["packages/tabs/src/index.ts"],
      "@lattice-ui/text-field": ["packages/text-field/src/index.ts"],
      "@lattice-ui/textarea": ["packages/textarea/src/index.ts"],
      "@lattice-ui/toast": ["packages/toast/src/index.ts"],
      "@lattice-ui/toggle-group": ["packages/toggle-group/src/index.ts"],
      "@lattice-ui/tooltip": ["packages/tooltip/src/index.ts"]
    },
    "typeRoots": ["./node_modules/@rbxts", "./node_modules/@lattice-ui"],
    "types": ["types", "compiler-types"]
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "apps/*/src/**/*.ts", "apps/*/src/**/*.tsx"]
}
