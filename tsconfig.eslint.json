      "@lattice-ui/react-slider": ["packages/react/slider/src/index.ts"],
      "@lattice-ui/react-style": ["packages/react/style/src/index.ts"],
      "@lattice-ui/react-system": ["packages/react/system/src/index.ts"],
      "@lattice-ui/react-switch": ["packages/react/switch/src/index.ts"],
      "@lattice-ui/react-tabs": ["packages/react/tabs/src/index.ts"],
      "@lattice-ui/react-text-field": ["packages/react/text-field/src/index.ts"],
      "@lattice-ui/react-textarea": ["packages/react/textarea/src/index.ts"],
      "@lattice-ui/react-toast": ["packages/react/toast/src/index.ts"],
      "@lattice-ui/react-toggle-group": ["packages/react/toggle-group/src/index.ts"],
      "@lattice-ui/react-tooltip": ["packages/react/tooltip/src/index.ts"]
    },
    "typeRoots": ["./node_modules/@rbxts", "./node_modules/@lattice-ui"],
    "types": ["types", "compiler-types"]
