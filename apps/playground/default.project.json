{
  "name": "lattice-ui-playground",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "node_modules": {
        "$className": "Folder",
        "@lattice-ui": {
          "$path": "node_modules/@lattice-ui"
        },
        "@rbxts": {
          "$path": "../../node_modules/@rbxts"
        }
      },
      "TS": {
        "$path": "include"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Playground": {
          "$path": "out/client"
        }
      }
    }
  }
}
